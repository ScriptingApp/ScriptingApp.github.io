  },
  "dependencies": {
    "rspress": "^1.45.6"
  },
  "devDependencies": {
    "@rspress/plugin-rss": "^1.45.6",
    "@types/node": "^24.7.2",
    "rspress-plugin-gh-pages": "^0.3.0"
  }
}
